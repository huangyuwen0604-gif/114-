/* ── MODAL ── */
function openModal(i) {
  const g = groups[i];
  const overlay = document.getElementById('modalOverlay');
  document.getElementById('modalHeader').style.background = g.bg;
  document.getElementById('modalHeader').textContent = g.emoji;
  document.getElementById('modalTitle').textContent = g.title;
  document.getElementById('modalInfoRow').innerHTML =
    `<span class="info-chip">研究 ${g.num}</span>
     <span class="info-chip">${g.subject}</span>
     <span class="info-chip">⏰ ${g.time}</span>
     <span class="info-chip">👩‍🏫 ${g.teacher}</span>`;
  document.getElementById('modalDesc').innerHTML =
    `<strong style="display:block;margin-bottom:8px;color:#374151">👥 發表學生：</strong>${g.members}<br><br>` +
    `<strong style="display:block;margin-bottom:8px;color:#374151">📝 研究簡介：</strong>` +
    g.desc.replace(/\n/g,'<br>');
  overlay.classList.add('open');
}
function closeModal(e) {
  if (e.target === document.getElementById('modalOverlay'))
    document.getElementById('modalOverlay').classList.remove('open');
}

/* ── VOTING ── */
const VOTE_KEY = 'shengli_vote_2025';
let votes = JSON.parse(localStorage.getItem(VOTE_KEY) || 'null') || {};
let myVote = localStorage.getItem(VOTE_KEY+'_mine') || null;

function buildVote() {
  const grid = document.getElementById('voteGrid');
  grid.innerHTML = '';
  groups.forEach((g, i) => {
    const count = votes[i] || 0;
    const isVoted = myVote == i;
    const btn = document.createElement('button');
    btn.className = 'vote-btn' + (isVoted ? ' voted' : '');
    btn.innerHTML = `<span class="vote-emoji">${g.emoji}</span>${g.title}<div class="vote-count">❤️ ${count} 票</div>`;
    btn.onclick = () => castVote(i);
    grid.appendChild(btn);
  });
  buildResults();
}

function castVote(i) {
  if (myVote !== null) {
    votes[myVote] = Math.max(0, (votes[myVote] || 0) - 1);
  }
  myVote = i;
  votes[i] = (votes[i] || 0) + 1;
  localStorage.setItem(VOTE_KEY, JSON.stringify(votes));
  localStorage.setItem(VOTE_KEY+'_mine', i);
  buildVote();
  document.getElementById('voteResults').style.display = 'block';
  // confetti burst
  confettiBurst();
}

function buildResults() {
  const total = Object.values(votes).reduce((a,b)=>a+b,0) || 1;
  const bars = document.getElementById('voteResultBars');
  bars.innerHTML = '';
  groups.forEach((g, i) => {
    const count = votes[i] || 0;
    const pct = Math.round(count/total*100);
    bars.innerHTML += `
      <div class="vote-result-bar-wrap">
        <div class="vote-result-label">
          <span>${g.emoji} ${g.title}</span>
          <span style="color:${g.color}">${count} 票（${pct}%）</span>
        </div>
        <div class="vote-bar-bg"><div class="vote-bar" style="width:${pct}%;background:${g.color}"></div></div>
      </div>`;
  });
}

function resetVote() {
  votes = {}; myVote = null;
  localStorage.removeItem(VOTE_KEY);
  localStorage.removeItem(VOTE_KEY+'_mine');
  document.getElementById('voteResults').style.display = 'none';
  buildVote();
}

buildVote();
if (myVote !== null) document.getElementById('voteResults').style.display = 'block';

/* ── COMMENTS ── */
const COMMENT_KEY = 'shengli_comments_2025';
let comments = JSON.parse(localStorage.getItem(COMMENT_KEY) || '[]');

function renderComments() {
  const list = document.getElementById('commentsList');
  const existing = list.children[0]; // keep seed comment
  while (list.children.length > 1) list.removeChild(list.lastChild);
  comments.slice().reverse().forEach(c => {
    const el = document.createElement('div');
    el.className = 'comment-item';
    el.innerHTML = `<div class="comment-name">💬 ${escHtml(c.name)}</div>
      <div class="comment-text">${escHtml(c.text)}</div>
      <div class="comment-time">${c.time}</div>`;
    list.appendChild(el);
  });
}

function addComment() {
  const name = document.getElementById('commentName').value.trim() || '匿名';
  const text = document.getElementById('commentText').value.trim();
  if (!text) { alert('請輸入留言內容！'); return; }
  const now = new Date();
  const time = `${now.getMonth()+1}/${now.getDate()} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
  comments.push({ name, text, time });
  localStorage.setItem(COMMENT_KEY, JSON.stringify(comments));
  document.getElementById('commentName').value = '';
  document.getElementById('commentText').value = '';
  renderComments();
  confettiBurst();
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
renderComments();

/* ── PARTICLES ── */
const canvas = document.getElementById('particles');
const ctx = canvas.getContext('2d');
let particles = [];
const COLORS = ['#ff6eb4','#a855f7','#3b82f6','#06b6d4','#22c55e','#facc15','#f97316'];
const SHAPES = ['★','♦','●','▲','♥','✦'];

function resize() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

function createParticle(x, y, burst) {
  return {
    x: x ?? Math.random() * canvas.width,
    y: y ?? Math.random() * canvas.height,
    vx: (Math.random()-0.5) * (burst ? 6 : 0.4),
    vy: burst ? (Math.random()-0.5)*6 : -Math.random()*0.5 - 0.2,
    size: Math.random()*12+6,
    color: COLORS[Math.floor(Math.random()*COLORS.length)],
    shape: SHAPES[Math.floor(Math.random()*SHAPES.length)],
    alpha: burst ? 1 : Math.random()*0.35+0.1,
    life: burst ? 1 : Infinity,
    decay: burst ? 0.015+Math.random()*0.01 : 0,
  };
}

// Initial ambient particles
for(let i=0;i<28;i++) particles.push(createParticle());

function confettiBurst() {
  const cx = canvas.width/2, cy = canvas.height/2;
  for(let i=0;i<50;i++) particles.push(createParticle(cx, cy, true));
}

function animate() {
  ctx.clearRect(0,0,canvas.width,canvas.height);
  particles = particles.filter(p => p.alpha > 0.01);
  // Replenish ambient
  while(particles.filter(p=>p.life===Infinity).length < 28) particles.push(createParticle());

  particles.forEach(p => {
    p.x += p.vx; p.y += p.vy;
    if(p.life !== Infinity) { p.alpha -= p.decay; }
    if(p.y < -20) { p.y = canvas.height + 20; p.x = Math.random()*canvas.width; }
    ctx.save();
    ctx.globalAlpha = Math.max(0,p.alpha);
    ctx.fillStyle = p.color;
    ctx.font = `${p.size}px serif`;
    ctx.fillText(p.shape, p.x, p.y);
    ctx.restore();
  });
  requestAnimationFrame(animate);
}
animate();

/* ── SCROLL ── */
window.addEventListener('scroll', () => {
  const btn = document.getElementById('scrollTop');
  btn.style.display = window.scrollY > 400 ? 'flex' : 'none';

  // Nav active state
  const sections = ['hero','schedule','presentations','posters','vote','comments'];
  let current = 'hero';
  sections.forEach(id => {
    const el = document.getElementById(id);
    if(el && el.getBoundingClientRect().top < 120) current = id;
  });
  document.querySelectorAll('nav a').forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#'+current);
  });
});

/* ── FADE IN OBSERVER ── */
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.12 });
document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
