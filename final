<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>數一數二語眾不同 ✨ 114學年度勝利國中資優班成果發表會</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --pink:    #ff6eb4;
    --purple:  #a855f7;
    --blue:    #3b82f6;
    --cyan:    #06b6d4;
    --green:   #22c55e;
    --yellow:  #facc15;
    --orange:  #f97316;
    --red:     #ef4444;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Noto Sans TC', sans-serif;
    background: #fff9fe;
    color: #2d1b4e;
    overflow-x: hidden;
  }

  /* ──────────────────── CANVAS PARTICLES ──────────────────── */
  #particles { position: fixed; inset: 0; pointer-events: none; z-index: 0; }

  /* ──────────────────── NAV ──────────────────── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 3px solid transparent;
    border-image: linear-gradient(90deg,var(--pink),var(--purple),var(--blue),var(--cyan)) 1;
    display: flex; align-items: center; justify-content: center;
    gap: 4px; padding: 10px 12px; flex-wrap: wrap;
  }
  nav a {
    text-decoration: none; color: #4b2d8a;
    font-weight: 700; font-size: 0.82rem;
    padding: 6px 12px; border-radius: 999px;
    transition: all .2s; white-space: nowrap;
    border: 2px solid transparent;
  }
  nav a:hover, nav a.active {
    background: linear-gradient(135deg,var(--pink),var(--purple));
    color: #fff; border-color: transparent;
    transform: scale(1.08);
  }

  /* ──────────────────── HERO ──────────────────── */
  #hero {
    min-height: 100svh;
    background: linear-gradient(160deg, #ffe4f8 0%, #e0d7ff 40%, #c7eeff 100%);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 90px 20px 60px;
    position: relative; overflow: hidden;
  }
  .hero-badge {
    display: inline-block;
    background: linear-gradient(135deg,var(--pink),var(--purple));
    color: #fff; font-size: 0.9rem; font-weight: 700;
    padding: 6px 20px; border-radius: 999px;
    margin-bottom: 18px; letter-spacing: .08em;
    box-shadow: 0 4px 18px rgba(168,85,247,.35);
    animation: popIn .6s ease both;
  }
  .hero-school {
    font-size: clamp(1rem, 3vw, 1.3rem);
    font-weight: 700; color: #6b21a8;
    margin-bottom: 12px;
    animation: popIn .7s ease both;
  }
  .hero-title {
    font-size: clamp(2.4rem, 10vw, 5.5rem);
    font-weight: 900; line-height: 1.15;
    background: linear-gradient(135deg,#ff6eb4,#a855f7,#3b82f6,#06b6d4);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: popIn .8s ease both;
    letter-spacing: -.01em;
  }
  .hero-sub {
    font-size: clamp(0.95rem, 2.5vw, 1.25rem);
    color: #6b21a8; margin-top: 14px; font-weight: 700;
    animation: popIn .9s ease both;
  }
  .hero-date {
    margin-top: 10px; font-size: 0.95rem; color: #7c3aed;
    animation: popIn 1s ease both;
  }
  .hero-buttons {
    display: flex; gap: 12px; flex-wrap: wrap;
    justify-content: center; margin-top: 30px;
    animation: popIn 1.1s ease both;
  }
  .btn {
    padding: 12px 28px; border-radius: 999px;
    font-size: 1rem; font-weight: 700; cursor: pointer;
    border: none; text-decoration: none;
    transition: transform .2s, box-shadow .2s;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .btn:active { transform: scale(0.96); }
  .btn-primary {
    background: linear-gradient(135deg,var(--pink),var(--purple));
    color: #fff;
    box-shadow: 0 6px 22px rgba(168,85,247,.4);
  }
  .btn-primary:hover { transform: translateY(-2px) scale(1.04); box-shadow: 0 10px 28px rgba(168,85,247,.5); }
  .btn-secondary {
    background: #fff; color: var(--purple);
    border: 2px solid var(--purple);
  }
  .btn-secondary:hover { background: #f5f0ff; transform: translateY(-2px); }

  .hero-deco {
    position: absolute; font-size: 3.5rem; opacity: .18;
    animation: float 4s ease-in-out infinite;
    user-select: none; pointer-events: none;
  }

  /* ──────────────────── SECTION WRAPPER ──────────────────── */
  section {
    position: relative; z-index: 1;
    padding: 70px 20px 50px;
    max-width: 860px; margin: 0 auto;
  }
  .section-tag {
    display: inline-block;
    background: linear-gradient(135deg,var(--pink),var(--orange));
    color: #fff; font-size: 0.78rem; font-weight: 700;
    padding: 4px 14px; border-radius: 999px; margin-bottom: 10px;
    letter-spacing: .1em;
  }
  h2.section-title {
    font-size: clamp(1.7rem, 5vw, 2.4rem);
    font-weight: 900; margin-bottom: 30px;
    background: linear-gradient(135deg,#7c3aed,#2563eb);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ──────────────────── TIMELINE ──────────────────── */
  .timeline { position: relative; padding-left: 28px; }
  .timeline::before {
    content: ''; position: absolute; left: 10px; top: 0; bottom: 0;
    width: 4px; border-radius: 4px;
    background: linear-gradient(180deg,var(--pink),var(--purple),var(--blue),var(--cyan));
  }
  .tl-item {
    position: relative; margin-bottom: 20px;
    background: #fff; border-radius: 18px;
    padding: 16px 18px 16px 20px;
    box-shadow: 0 4px 18px rgba(107,33,168,.08);
    border-left: 4px solid var(--c, var(--purple));
    transition: transform .2s, box-shadow .2s;
  }
  .tl-item:hover { transform: translateX(4px); box-shadow: 0 8px 28px rgba(107,33,168,.15); }
  .tl-dot {
    position: absolute; left: -38px; top: 18px;
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--c, var(--purple));
    border: 3px solid #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem; box-shadow: 0 2px 8px rgba(0,0,0,.18);
  }
  .tl-time {
    font-size: 0.78rem; font-weight: 700; color: var(--c, var(--purple));
    margin-bottom: 4px; letter-spacing: .04em;
  }
  .tl-title { font-size: 1.1rem; font-weight: 900; margin-bottom: 2px; }
  .tl-desc { font-size: 0.88rem; color: #6b21a8; }

  /* ──────────────────── PRESENTATION TABLE ──────────────────── */
  .pres-table-wrap { overflow-x: auto; border-radius: 18px; box-shadow: 0 4px 20px rgba(107,33,168,.1); }
  table.pres-table {
    width: 100%; border-collapse: collapse;
    background: #fff; font-size: 0.85rem;
    border-radius: 18px; overflow: hidden;
  }
  .pres-table thead tr {
    background: linear-gradient(135deg,#7c3aed,#3b82f6);
    color: #fff;
  }
  .pres-table th { padding: 12px 10px; font-weight: 700; text-align: center; }
  .pres-table td { padding: 11px 10px; text-align: center; border-bottom: 1px solid #f0e8ff; vertical-align: middle; }
  .pres-table tbody tr:hover { background: #faf5ff; }
  .pres-table tbody tr:last-child td { border-bottom: none; }
  .subject-tag {
    display: inline-block; padding: 3px 10px;
    border-radius: 999px; font-size: 0.75rem; font-weight: 700;
    color: #fff;
  }

  /* ──────────────────── POSTER CARDS ──────────────────── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
  }
  .card {
    background: #fff; border-radius: 22px;
    overflow: hidden; cursor: pointer;
    box-shadow: 0 4px 20px rgba(107,33,168,.1);
    transition: transform .25s, box-shadow .25s;
    border: 2px solid transparent;
  }
  .card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 14px 36px rgba(107,33,168,.2);
    border-color: var(--card-color);
  }
  .card-header {
    height: 130px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    background: var(--card-bg, linear-gradient(135deg,var(--pink),var(--purple)));
    font-size: 2.8rem; gap: 6px;
    position: relative; overflow: hidden;
  }
  .card-header::after {
    content: ''; position: absolute; inset: 0;
    background: rgba(255,255,255,.08);
  }
  .card-img {
    width: 100%; height: 180px; object-fit: cover; display: block;
  }
  .card-body { padding: 14px 16px 16px; }
  .card-num {
    font-size: 0.72rem; font-weight: 700; color: var(--card-color);
    text-transform: uppercase; letter-spacing: .08em; margin-bottom: 4px;
  }
  .card-title { font-size: 1.05rem; font-weight: 900; margin-bottom: 8px; line-height: 1.3; }
  .card-subject {
    display: inline-block; padding: 3px 10px;
    border-radius: 999px; font-size: 0.72rem; font-weight: 700;
    background: #f0e8ff; color: var(--card-color);
    margin-bottom: 8px;
  }
  .card-members {
    font-size: 0.78rem; color: #6b7280; line-height: 1.6;
  }
  .card-teacher {
    font-size: 0.78rem; color: #9333ea; margin-top: 6px;
    font-weight: 700;
  }
  .card-time {
    font-size: 0.72rem; background: #fdf4ff;
    color: var(--card-color); font-weight: 700;
    padding: 3px 10px; border-radius: 999px;
    margin-top: 8px; display: inline-block;
  }

  /* ──────────────────── MODAL ──────────────────── */
  .modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 200;
    background: rgba(45,27,78,.6); backdrop-filter: blur(8px);
    align-items: center; justify-content: center; padding: 20px;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: #fff; border-radius: 28px;
    max-width: 480px; width: 100%;
    max-height: 90svh; overflow-y: auto;
    box-shadow: 0 20px 60px rgba(107,33,168,.35);
    animation: popIn .3s ease both;
  }
  .modal-header {
    height: 180px; display: flex; align-items: center; justify-content: center;
    font-size: 4rem; border-radius: 28px 28px 0 0;
  }
  .modal-body { padding: 24px; }
  .modal-body h3 { font-size: 1.5rem; font-weight: 900; margin-bottom: 8px; }
  .modal-body .info-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; }
  .info-chip {
    padding: 4px 12px; border-radius: 999px; font-size: 0.8rem;
    font-weight: 700; background: #f0e8ff; color: #6b21a8;
  }
  .modal-body p { font-size: 0.9rem; color: #4b5563; line-height: 1.7; }
  .modal-close {
    width: 100%; margin-top: 20px; padding: 12px;
    border-radius: 999px; border: none; cursor: pointer;
    background: linear-gradient(135deg,var(--pink),var(--purple));
    color: #fff; font-size: 1rem; font-weight: 700;
    font-family: inherit;
  }

  /* ──────────────────── VOTING ──────────────────── */
  #vote { background: linear-gradient(160deg,#fdf4ff,#eff6ff); border-radius: 32px; padding: 40px 24px; }
  .vote-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px,1fr));
    gap: 14px; margin-bottom: 24px;
  }
  .vote-btn {
    padding: 14px 10px; border-radius: 18px;
    border: 2px solid #e9d5ff; background: #fff;
    cursor: pointer; font-family: inherit;
    font-size: 0.85rem; font-weight: 700;
    color: #4b2d8a; text-align: center;
    transition: all .2s; position: relative;
    overflow: hidden;
  }
  .vote-btn:hover {
    border-color: var(--purple); background: #fdf4ff;
    transform: scale(1.03);
  }
  .vote-btn.voted {
    background: linear-gradient(135deg,var(--pink),var(--purple));
    color: #fff; border-color: transparent;
    box-shadow: 0 6px 18px rgba(168,85,247,.35);
  }
  .vote-btn .vote-emoji { font-size: 1.6rem; display: block; margin-bottom: 6px; }
  .vote-btn .vote-count {
    font-size: 0.75rem; margin-top: 6px;
    opacity: .8; font-weight: 700;
  }
  .vote-result-bar-wrap { margin-bottom: 12px; }
  .vote-result-label { display: flex; justify-content: space-between; font-size: 0.82rem; font-weight: 700; margin-bottom: 4px; }
  .vote-bar-bg { background: #e9d5ff; border-radius: 999px; height: 10px; overflow: hidden; }
  .vote-bar { height: 100%; border-radius: 999px; background: linear-gradient(90deg,var(--pink),var(--purple)); transition: width .6s ease; }

  /* ──────────────────── COMMENTS ──────────────────── */
  .comment-form { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 24px; }
  .comment-form input, .comment-form textarea {
    border: 2px solid #e9d5ff; border-radius: 14px;
    padding: 10px 14px; font-family: inherit; font-size: 0.9rem;
    color: #2d1b4e; outline: none; transition: border-color .2s;
    background: #fff;
  }
  .comment-form input:focus, .comment-form textarea:focus { border-color: var(--purple); }
  .comment-form input { width: 160px; }
  .comment-form textarea { flex: 1; min-width: 200px; resize: none; height: 46px; }
  .comment-form button {
    padding: 10px 22px; border-radius: 999px; border: none;
    background: linear-gradient(135deg,var(--pink),var(--purple));
    color: #fff; font-size: 0.9rem; font-weight: 700;
    cursor: pointer; font-family: inherit;
    transition: transform .2s, box-shadow .2s;
    white-space: nowrap;
  }
  .comment-form button:hover { transform: scale(1.05); box-shadow: 0 6px 18px rgba(168,85,247,.4); }
  .comments-list { display: flex; flex-direction: column; gap: 12px; }
  .comment-item {
    background: #fff; border-radius: 16px;
    padding: 14px 16px; box-shadow: 0 2px 12px rgba(107,33,168,.07);
    animation: popIn .3s ease both;
  }
  .comment-name { font-size: 0.82rem; font-weight: 700; color: var(--purple); margin-bottom: 4px; }
  .comment-text { font-size: 0.9rem; color: #374151; line-height: 1.6; }
  .comment-time { font-size: 0.72rem; color: #9ca3af; margin-top: 4px; }

  /* ──────────────────── FOOTER ──────────────────── */
  footer {
    text-align: center; padding: 30px 20px 40px;
    font-size: 0.82rem; color: #a78bfa;
    background: linear-gradient(135deg,#fdf4ff,#eff6ff);
  }
  footer strong { color: var(--purple); }

  /* ──────────────────── ANIMATIONS ──────────────────── */
  @keyframes popIn {
    from { opacity: 0; transform: translateY(18px) scale(.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes float {
    0%,100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-18px) rotate(8deg); }
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .fade-in {
    opacity: 0; transform: translateY(30px);
    transition: opacity .6s ease, transform .6s ease;
  }
  .fade-in.visible { opacity: 1; transform: translateY(0); }

  /* ──────────────────── SCROLL TOP ──────────────────── */
  #scrollTop {
    position: fixed; bottom: 24px; right: 24px; z-index: 150;
    width: 48px; height: 48px; border-radius: 50%;
    background: linear-gradient(135deg,var(--pink),var(--purple));
    border: none; color: #fff; font-size: 1.2rem;
    cursor: pointer; box-shadow: 0 6px 20px rgba(168,85,247,.4);
    display: none; align-items: center; justify-content: center;
    transition: transform .2s;
  }
  #scrollTop:hover { transform: scale(1.1); }

  /* Mobile tweaks */
  @media (max-width: 480px) {
    .cards-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
    .card-header { height: 100px; font-size: 2.2rem; }
    .vote-grid { grid-template-columns: 1fr 1fr; }
    .comment-form input { width: 100%; }
  }
</style>
</head>
<body>

<canvas id="particles"></canvas>

<!-- NAV -->
<nav id="mainNav">
  <a href="#hero">🏠 首頁</a>
  <a href="#schedule">📋 流程</a>
  <a href="#presentations">🔬 發表</a>
  <a href="#posters">🖼️ 海報</a>
  <a href="#vote">⭐ 投票</a>
  <a href="#comments">💬 留言</a>
</nav>

<!-- HERO -->
<div id="hero">
  <span class="hero-deco" style="top:8%;left:6%;animation-delay:0s">✨</span>
  <span class="hero-deco" style="top:12%;right:8%;animation-delay:.5s">🌟</span>
  <span class="hero-deco" style="bottom:18%;left:4%;animation-delay:1s">🎉</span>
  <span class="hero-deco" style="bottom:15%;right:5%;animation-delay:1.5s">🎊</span>
  <span class="hero-deco" style="top:40%;left:2%;animation-delay:.8s;font-size:2rem">💫</span>
  <span class="hero-deco" style="top:35%;right:3%;animation-delay:1.2s;font-size:2rem">🌈</span>

  <div class="hero-badge">🏫 114學年度 勝利國中資優班成果發表會</div>
  <div class="hero-school">勝利國中 × 資優教育</div>
  <h1 class="hero-title">數一數二<br>語眾不同</h1>
  <p class="hero-sub">用數字說故事，用語言創奇蹟</p>
  <p class="hero-date">📅 114年（2025年）成果發表會 ｜ 13:30 開始</p>
  <div class="hero-buttons">
    <a href="#schedule" class="btn btn-primary">📋 查看流程表</a>
    <a href="#posters" class="btn btn-secondary">🖼️ 瀏覽海報</a>
  </div>
</div>

<!-- ═══ 流程表 ═══ -->
<section id="schedule">
  <div class="section-tag">📋 今日流程</div>
  <h2 class="section-title">活動流程表</h2>

  <div class="timeline fade-in">

    <div class="tl-item" style="--c:var(--pink)">
      <div class="tl-dot">🎉</div>
      <div class="tl-time">13:30 ～ 13:40</div>
      <div class="tl-title">入場</div>
      <div class="tl-desc">歡迎來賓入場</div>
    </div>

    <div class="tl-item" style="--c:var(--purple)">
      <div class="tl-dot">🎤</div>
      <div class="tl-time">13:40 ～ 13:50</div>
      <div class="tl-title">致詞</div>
      <div class="tl-desc">校長、輔導主任致詞</div>
    </div>

    <div class="tl-item" style="--c:var(--blue)">
